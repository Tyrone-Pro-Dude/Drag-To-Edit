{
  "manifest_version": 3,
  "name": "FluxEdit",
  "version": "1.0",
  "description": "Drag images to the corner to open the built-in quick canvas editor.",
  "permissions": [
    "clipboardWrite", 
    "clipboardRead", 
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}